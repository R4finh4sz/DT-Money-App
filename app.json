{
  "expo": {
    "name": "DtMoney",
    "slug": "dtmoney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/expo/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.r4finh4sz.dtmoney"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/expo/splash-icon.png"
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6aeb2156-f98c-4879-a86b-a300579a787d"
      }
    },
    "owner": "r4finh4sz"
  }
}
